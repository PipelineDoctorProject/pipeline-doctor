# OpsSight backend application settings.
# Copy this file to backend/fastapi/.env for local development.
# In production, inject these values from your platform secret manager.

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
APP_ENV=development
SECRET_KEY=replace_with_a_real_32_plus_byte_secret
ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Use your Supabase Postgres/session-pooler connection values here.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace_me
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require

# Keep pools conservative for Supabase session pooler.
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=15
DB_POOL_RECYCLE=300

# ---------------------------------------------------------------------------
# Runtime services
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
MLFLOW_TRACKING_URI=http://mlflow:5000
FRONTEND_URL=http://localhost:5173
CLEANED_OUTPUT_DIR=cleaned
QUARANTINE_OUTPUT_DIR=cleaned/quarantine

# ---------------------------------------------------------------------------
# Email / OTP / invitations
# ---------------------------------------------------------------------------
MAIL_USERNAME=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM=replace_me@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=OpsSight.ai

# ---------------------------------------------------------------------------
# AI root cause and report generation
# ---------------------------------------------------------------------------
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Evidently Cloud
# ---------------------------------------------------------------------------
EVIDENTLY_TOKEN=replace_me
EVIDENTLY_PROJECT_ID=replace_me
EVIDENTLY_PROJECT_NAME=pipeline-doctor

# ---------------------------------------------------------------------------
# Slack OAuth app
# ---------------------------------------------------------------------------
SLACK_CLIENT_ID=replace_me
SLACK_CLIENT_SECRET=replace_me
SLACK_REDIRECT_URI=http://localhost:8000/slack/callback
SLACK_BOT_SCOPES=chat:write,chat:write.public,channels:read,channels:join,groups:read

# ---------------------------------------------------------------------------
# Data quality and cleaning thresholds
# ---------------------------------------------------------------------------
DATA_QUALITY_NULL_RATIO_THRESHOLD=0.30
DATA_QUALITY_ROW_ISSUE_THRESHOLD=0.70
DATA_QUALITY_MIN_CLEAN_ROW_COUNT=10
DATA_QUALITY_MIN_CLEAN_ROW_RATIO=0.50
DATA_QUALITY_CATEGORICAL_LIMIT=50
DATA_QUALITY_HIGH_CARDINALITY_LIMIT=200
DATA_QUALITY_HIGH_CARDINALITY_RATIO=0.20

# ---------------------------------------------------------------------------
# Remediation and retraining safeguards
# ---------------------------------------------------------------------------
REMEDIATION_MIN_TRAINING_ROWS=25
REMEDIATION_MAX_TARGET_NULL_RATIO=0.10
REMEDIATION_MAX_CLASS_COUNT=20
REMEDIATION_MAX_CLASS_UNIQUE_RATIO=0.35
REMEDIATION_MIN_CLASS_COUNT=3
REMEDIATION_TEST_SIZE=0.20
REMEDIATION_STAGING_ALIAS=staging
REMEDIATION_CHAMPION_ALIAS=champion
REMEDIATION_PROMOTION_ALIAS=staging
REMEDIATION_TASK_SOFT_TIME_LIMIT_SECONDS=300
REMEDIATION_TASK_TIME_LIMIT_SECONDS=360
REMEDIATION_MLFLOW_REQUEST_TIMEOUT_SECONDS=30
REMEDIATION_MLFLOW_MAX_RETRIES=1
REMEDIATION_CANDIDATE_MLFLOW_TRACKING_URI=http://mlflow:5000
REMEDIATION_MLFLOW_RUN_ARTIFACT_PATHS=model,candidate_model
