# Docker Compose / Airflow deployment settings.
# Keep real values in .env locally or in your production secret manager.

APP_ENV=development

# Airflow -> OpsSight API connection.
# Production should use a scoped service token or service identity in a secrets
# backend. Development can still use login/password through the Airflow UI.
OPSSIGHT_CONN_ID=opssight_api
AIRFLOW_CONN_OPSSIGHT_API={"conn_type":"http","host":"http://api","port":8000,"extra":{"api_url":"http://api:8000","api_token":"replace_me_service_token"}}
AIRFLOW_VAR_OPSSIGHT_API_URL=http://api:8000

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=replace_me
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

AIRFLOW_FERNET_KEY=replace_me
AIRFLOW_WEBSERVER_SECRET_KEY=replace_me
AIRFLOW_DB_PASSWORD=replace_me
AIRFLOW_DATABASE_SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:replace_me@airflow-db/airflow

# MLflow local service settings.
# Production should replace these with managed Postgres and durable object
# storage such as S3/GCS/Azure Blob.
MLFLOW_DB_PASSWORD=replace_me
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlflow:replace_me@mlflow-db/mlflow
MLFLOW_ARTIFACT_ROOT=/app/mlartifacts

# Remediation retraining safeguards.
# Candidate models are written to the OpsSight-controlled registry, even when
# the source model is loaded from an external registry.
REMEDIATION_CANDIDATE_MLFLOW_TRACKING_URI=http://mlflow:5000
# If a model was registered from a raw MLflow run, OpsSight tries these artifact
# paths in order after registered model aliases/versions.
REMEDIATION_MLFLOW_RUN_ARTIFACT_PATHS=model,candidate_model

# Database pooling.
# Supabase session pooler has strict connection limits, so keep per-process
# pools small. Scale through PgBouncer/transaction pooling in production.
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=15
DB_POOL_RECYCLE=300

# Docker service-specific pool overrides.
# API needs more room because the incident drawer loads several protected
# resources in parallel. Workers stay smaller to avoid exhausting the upstream
# database pool.
API_DB_POOL_SIZE=8
API_DB_MAX_OVERFLOW=0
API_DB_POOL_TIMEOUT=30
WORKER_DB_POOL_SIZE=2
WORKER_DB_MAX_OVERFLOW=0
WORKER_DB_POOL_TIMEOUT=15
BEAT_DB_POOL_SIZE=1
BEAT_DB_MAX_OVERFLOW=0
BEAT_DB_POOL_TIMEOUT=15
