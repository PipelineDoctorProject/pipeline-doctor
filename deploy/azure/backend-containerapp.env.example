# Example backend runtime settings for Azure Container Apps.
# Store real values as Container App secrets or Key Vault references.

APP_ENV=production
SECRET_KEY=replace_with_32_plus_byte_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DB_HOST=your-postgres-host.postgres.database.azure.com
DB_PORT=5432
DB_NAME=opssight
DB_USER=opssight_admin
DB_PASSWORD=replace_with_secret
DB_SSLMODE=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

REDIS_URL=rediss://:replace_with_secret@your-redis.redis.cache.windows.net:6380/0
FRONTEND_URL=https://your-frontend-domain
MLFLOW_TRACKING_URI=https://your-mlflow-domain
REMEDIATION_CANDIDATE_MLFLOW_TRACKING_URI=https://your-mlflow-domain

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=replace_with_secret
SMTP_FROM_EMAIL=no-reply@your-domain.com

SLACK_CLIENT_ID=replace_with_secret
SLACK_CLIENT_SECRET=replace_with_secret
SLACK_REDIRECT_URI=https://your-api-domain/slack/callback

GROQ_API_KEY=replace_with_secret
GROQ_MODEL=llama-3.3-70b-versatile

CLEANED_OUTPUT_DIR=/app/cleaned
QUARANTINE_OUTPUT_DIR=/app/cleaned/quarantine
UPLOAD_DIR=/app/uploads
